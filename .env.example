# Порядок фундаментальных провайдеров (sam3,anthropic,vllm). Для текста: anthropic, vllm.
# DEMO_FOUNDATION_PROVIDERS=vllm,anthropic

# Anthropic Messages API — для anthropic нужен ключ; базовый URL по умолчанию https://api.anthropic.com
ANTHROPIC_API_KEY=
# Необязательно — корпоративный шлюз; иначе прямое обращение к api.anthropic.com
ANTHROPIC_PROXY_URL=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=

# OpenAI-compatible vLLM:
# DEMO_VLLM_BASE_URL=
# DEMO_VLLM_API_KEY=
# DEMO_VLLM_MODEL=

# SAM3 (сегментация изображений):
# SAM3_API_BASE_URL=
# SAM3_API_KEY=
